{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Scientist Research Idea",
  "description": "Schema for a research idea generated by the ideation phase. Mirrors the output format from AI-Scientist-v2's perform_ideation_temp_free.py.",
  "type": "object",
  "required": ["Name", "Title", "Short Hypothesis", "Abstract", "Experiments"],
  "properties": {
    "Name": {
      "type": "string",
      "description": "Machine-readable identifier (lowercase, underscores, no spaces)",
      "pattern": "^[a-z0-9_]+$"
    },
    "Title": {
      "type": "string",
      "description": "Human-readable, informative title for the research"
    },
    "Short Hypothesis": {
      "type": "string",
      "description": "Core research question or hypothesis in 1-2 sentences"
    },
    "Related Work": {
      "type": "string",
      "description": "How this work distinguishes from existing literature"
    },
    "Abstract": {
      "type": "string",
      "description": "Conference-style abstract (~250 words)"
    },
    "Experiments": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of feasible experiments with metrics"
        },
        {
          "type": "string",
          "description": "Free-text description of experiments"
        }
      ]
    },
    "Risk Factors and Limitations": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "string"
        }
      ],
      "description": "Potential issues and limitations"
    }
  },
  "additionalProperties": true
}
